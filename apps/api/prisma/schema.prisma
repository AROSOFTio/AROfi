generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PackageStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PricingStrategy {
  FIXED
}

enum VoucherBatchStatus {
  DRAFT
  ACTIVE
  EXHAUSTED
  CANCELLED
}

enum VoucherStatus {
  GENERATED
  SOLD
  REDEEMED
  EXPIRED
  VOID
}

enum BillingChannel {
  MOBILE_MONEY
  VOUCHER
  WALLET_ADJUSTMENT
  FLOAT_TRANSFER
  COMMISSION
  DISBURSEMENT
  SYSTEM
}

enum BillingTransactionType {
  MOBILE_MONEY_SALE
  VOUCHER_SALE
  VOUCHER_REDEMPTION
  WALLET_ADJUSTMENT
  AGENT_FLOAT_TOPUP
  AGENT_FLOAT_RETURN
  AGENT_COMMISSION
  AGENT_DISBURSEMENT
}

enum BillingTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum PaymentProvider {
  YO_UGANDA
}

enum PaymentMethod {
  MOBILE_MONEY
}

enum PaymentNetwork {
  MTN
  AIRTEL
  UNKNOWN
}

enum PaymentStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  INDETERMINATE
  CANCELLED
  EXPIRED
}

enum PaymentEventType {
  REQUESTED
  STATUS_CHECK
  WEBHOOK_RECEIVED
  WEBHOOK_PROCESSED
  WEBHOOK_REJECTED
  STATE_TRANSITION
  ACTIVATION_POSTED
  ACTIVATION_FAILED
}

enum RouterVendor {
  MIKROTIK
}

enum RouterConnectionMode {
  ROUTEROS_API
  ROUTEROS_API_SSL
}

enum RouterStatus {
  PENDING
  HEALTHY
  DEGRADED
  OFFLINE
}

enum RadiusClientStatus {
  ACTIVE
  DISABLED
}

enum RadiusEventType {
  ACCESS_REQUEST
  ACCESS_ACCEPT
  ACCESS_REJECT
  ACCOUNTING_START
  ACCOUNTING_INTERIM
  ACCOUNTING_STOP
  COA_REQUEST
  DISCONNECT_REQUEST
}

enum SessionStatus {
  ACTIVE
  CLOSED
  STALE
}

enum WalletOwnerType {
  TENANT
  AGENT
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum LedgerTransactionType {
  SALE
  WALLET_ADJUSTMENT
  REDEMPTION
  FLOAT_TRANSFER
  COMMISSION
  DISBURSEMENT
}

enum AgentType {
  FIELD_AGENT
  RESELLER
}

enum AgentStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum CommissionStatus {
  ACCRUED
  SETTLED
  REVERSED
}

enum SettlementStatus {
  DRAFT
  READY
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum DisbursementMethod {
  MOBILE_MONEY
  BANK_TRANSFER
  CASH
  MANUAL
}

enum DisbursementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PackageActivationSource {
  MOBILE_MONEY
  VOUCHER
}

enum PackageActivationStatus {
  PENDING
  ACTIVE
  EXPIRED
  FAILED
  REVOKED
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum FeatureLimitCategory {
  CATALOG
  NETWORK
  SALES
  SUPPORT
  OPERATIONS
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum SupportTicketChannel {
  PORTAL
  EMAIL
  PHONE
  INTERNAL
}

model Tenant {
  id                  String               @id @default(uuid())
  name                String
  domain              String?              @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               User[]
  agents              Agent[]
  hotspots            Hotspot[]
  packages            Package[]
  voucherBatches      VoucherBatch[]
  vouchers            Voucher[]
  wallets             Wallet[]
  billingTransactions BillingTransaction[]
  ledgerTransactions  LedgerTransaction[]
  ledgerEntries       LedgerEntry[]
  agentCommissions    AgentCommission[]
  settlements         Settlement[]
  disbursements       Disbursement[]
  voucherRedemptions  VoucherRedemption[]
  payments            Payment[]
  paymentWebhooks     PaymentWebhook[]
  packageActivations  PackageActivation[]
  routerGroups        RouterGroup[]
  routers             Router[]
  routerHealthChecks  RouterHealthCheck[]
  radiusClients       RadiusClient[]
  radiusEvents        RadiusEvent[]
  networkSessions     NetworkSession[]
  featureLimits       FeatureLimit[]
  supportTickets      SupportTicket[]
  auditLogs           AuditLog[]
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions String[]
  users       User[]
}

model User {
  id                     String            @id @default(uuid())
  email                  String            @unique
  password               String
  firstName              String?
  lastName               String?
  roleId                 String
  role                   Role              @relation(fields: [roleId], references: [id])
  tenantId               String?
  tenant                 Tenant?           @relation(fields: [tenantId], references: [id])
  isActive               Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  generatedVoucherBatches VoucherBatch[]   @relation("VoucherBatchGenerator")
  voucherRedemptions     VoucherRedemption[] @relation("VoucherRedemptionActor")
}

model Agent {
  id                String            @id @default(uuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  code              String
  name              String
  phoneNumber       String
  email             String?
  type              AgentType         @default(FIELD_AGENT)
  status            AgentStatus       @default(ACTIVE)
  territory         String?
  commissionRateBps Int               @default(500)
  floatLimitUgx     Int               @default(0)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  wallet            Wallet?
  transactions      BillingTransaction[]
  commissions       AgentCommission[]
  settlements       Settlement[]
  disbursements     Disbursement[]

  @@unique([tenantId, code])
  @@unique([tenantId, phoneNumber])
  @@index([tenantId, status])
}

model Hotspot {
  id                 String              @id @default(uuid())
  name               String
  nasIpAddress       String?
  secret             String?
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  voucherRedemptions VoucherRedemption[]
  packageActivations PackageActivation[]
  routers            Router[]
  radiusEvents       RadiusEvent[]
  networkSessions    NetworkSession[]
}

model RouterGroup {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  code        String
  description String?
  region      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  routers     Router[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
}

model Router {
  id                    String               @id @default(uuid())
  tenantId              String
  tenant                Tenant               @relation(fields: [tenantId], references: [id])
  groupId               String?
  group                 RouterGroup?         @relation(fields: [groupId], references: [id])
  hotspotId             String?
  hotspot               Hotspot?             @relation(fields: [hotspotId], references: [id])
  name                  String
  identity              String?
  vendor                RouterVendor         @default(MIKROTIK)
  host                  String
  apiPort               Int                  @default(8728)
  connectionMode        RouterConnectionMode @default(ROUTEROS_API)
  username              String
  passwordCiphertext    String
  sharedSecretCiphertext String
  siteLabel             String?
  model                 String?
  serialNumber          String?
  routerOsVersion       String?
  status                RouterStatus         @default(PENDING)
  healthMessage         String?
  lastSeenAt            DateTime?
  lastHealthCheckAt     DateTime?
  lastLatencyMs         Int?
  activeSessionCount    Int                  @default(0)
  lastProvisionedAt     DateTime?
  tags                  String[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  radiusClient          RadiusClient?
  healthChecks          RouterHealthCheck[]
  radiusEvents          RadiusEvent[]
  sessions              NetworkSession[]

  @@unique([tenantId, host])
  @@index([tenantId, status])
  @@index([groupId])
}

model RouterHealthCheck {
  id               String       @id @default(uuid())
  tenantId         String
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  routerId         String
  router           Router       @relation(fields: [routerId], references: [id])
  status           RouterStatus
  latencyMs        Int?
  message          String?
  cpuUsagePercent  Int?
  memoryUsagePercent Int?
  activeUsers      Int?
  rawPayload       Json?
  checkedAt        DateTime     @default(now())

  @@index([tenantId, checkedAt])
  @@index([routerId, checkedAt])
}

model RadiusClient {
  id               String             @id @default(uuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  routerId         String             @unique
  router           Router             @relation(fields: [routerId], references: [id])
  shortName        String
  ipAddress        String
  secretCiphertext String
  status           RadiusClientStatus @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([tenantId, status])
}

model RadiusEvent {
  id                String          @id @default(uuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  routerId          String?
  router            Router?         @relation(fields: [routerId], references: [id])
  hotspotId         String?
  hotspot           Hotspot?        @relation(fields: [hotspotId], references: [id])
  sessionId         String?
  session           NetworkSession? @relation(fields: [sessionId], references: [id])
  eventType         RadiusEventType
  username          String?
  customerReference String?
  phoneNumber       String?
  macAddress        String?
  ipAddress         String?
  nasIpAddress      String?
  authMethod        String?
  responseCode      String?
  message           String?
  payload           Json?
  createdAt         DateTime        @default(now())

  @@index([tenantId, createdAt])
  @@index([routerId, createdAt])
  @@index([sessionId, createdAt])
}

model NetworkSession {
  id                  String             @id @default(uuid())
  tenantId            String
  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  routerId            String?
  router              Router?            @relation(fields: [routerId], references: [id])
  hotspotId           String?
  hotspot             Hotspot?           @relation(fields: [hotspotId], references: [id])
  activationId        String?
  activation          PackageActivation? @relation(fields: [activationId], references: [id])
  voucherRedemptionId String?
  voucherRedemption   VoucherRedemption? @relation(fields: [voucherRedemptionId], references: [id])
  radiusSessionId     String
  status              SessionStatus      @default(ACTIVE)
  username            String
  customerReference   String?
  phoneNumber         String?
  macAddress          String?
  ipAddress           String?
  nasIpAddress        String?
  packageName         String?
  startedAt           DateTime           @default(now())
  endedAt             DateTime?
  sessionTimeSeconds  Int                @default(0)
  inputOctets         BigInt             @default(0)
  outputOctets        BigInt             @default(0)
  lastAccountingAt    DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  radiusEvents        RadiusEvent[]

  @@unique([tenantId, radiusSessionId])
  @@index([tenantId, status, startedAt])
  @@index([routerId, status])
}

model Package {
  id                  String               @id @default(uuid())
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  name                String
  code                String
  description         String?
  durationMinutes     Int
  dataLimitMb         Int?
  deviceLimit         Int?
  downloadSpeedKbps   Int?
  uploadSpeedKbps     Int?
  isFeatured          Boolean              @default(false)
  status              PackageStatus        @default(DRAFT)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  prices              PackagePrice[]
  voucherBatches      VoucherBatch[]
  vouchers            Voucher[]
  billingTransactions BillingTransaction[]
  voucherRedemptions  VoucherRedemption[]
  payments            Payment[]
  packageActivations  PackageActivation[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model PackagePrice {
  id          String          @id @default(uuid())
  packageId   String
  package     Package         @relation(fields: [packageId], references: [id])
  amountUgx   Int
  currency    String          @default("UGX")
  strategy    PricingStrategy @default(FIXED)
  isDefault   Boolean         @default(true)
  startsAt    DateTime        @default(now())
  endsAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([packageId, startsAt])
}

model VoucherBatch {
  id                String            @id @default(uuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  packageId         String
  package           Package           @relation(fields: [packageId], references: [id])
  generatedByUserId String?
  generatedByUser   User?             @relation("VoucherBatchGenerator", fields: [generatedByUserId], references: [id])
  batchNumber       String            @unique
  prefix            String
  quantity          Int
  faceValueUgx      Int
  expiresAt         DateTime?
  status            VoucherBatchStatus @default(ACTIVE)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  vouchers          Voucher[]

  @@index([tenantId, createdAt])
}

model Voucher {
  id                  String               @id @default(uuid())
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  batchId             String
  batch               VoucherBatch         @relation(fields: [batchId], references: [id])
  packageId           String
  package             Package              @relation(fields: [packageId], references: [id])
  code                String               @unique
  serialNumber        String               @unique
  faceValueUgx        Int
  status              VoucherStatus        @default(GENERATED)
  soldAt              DateTime?
  redeemedAt          DateTime?
  expiresAt           DateTime?
  soldToReference     String?
  customerReference   String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  billingTransactions BillingTransaction[]
  redemption          VoucherRedemption?

  @@index([tenantId, status])
}

model Wallet {
  id                  String               @id @default(uuid())
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  ownerType           WalletOwnerType      @default(TENANT)
  ownerReference      String
  agentId             String?              @unique
  agent               Agent?               @relation(fields: [agentId], references: [id])
  currency            String               @default("UGX")
  balanceUgx          Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ledgerTransactions  LedgerTransaction[]
  ledgerEntries       LedgerEntry[]
  billingTransactions BillingTransaction[]
  commissions         AgentCommission[]
  settlements         Settlement[]
  disbursements       Disbursement[]

  @@unique([tenantId, ownerType, ownerReference])
  @@index([agentId])
}

model BillingTransaction {
  id                  String                   @id @default(uuid())
  tenantId            String
  tenant              Tenant                   @relation(fields: [tenantId], references: [id])
  walletId            String?
  wallet              Wallet?                  @relation(fields: [walletId], references: [id])
  agentId             String?
  agent               Agent?                   @relation(fields: [agentId], references: [id])
  packageId           String?
  package             Package?                 @relation(fields: [packageId], references: [id])
  voucherId           String?
  voucher             Voucher?                 @relation(fields: [voucherId], references: [id])
  ledgerTransactionId String?                  @unique
  ledgerTransaction   LedgerTransaction?       @relation(fields: [ledgerTransactionId], references: [id])
  channel             BillingChannel
  type                BillingTransactionType
  status              BillingTransactionStatus @default(COMPLETED)
  grossAmountUgx      Int
  feeAmountUgx        Int                      @default(0)
  netAmountUgx        Int                      @default(0)
  customerReference   String?
  externalReference   String?                  @unique
  paymentProvider     String?
  metadata            Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  payment             Payment?
  sourceCommission    AgentCommission?         @relation("AgentCommissionSource")
  payoutCommission    AgentCommission?         @relation("AgentCommissionPayout")
  disbursement        Disbursement?

  @@index([tenantId, createdAt])
  @@index([type, status])
  @@index([agentId, createdAt])
}

model LedgerTransaction {
  id                  String               @id @default(uuid())
  tenantId            String?
  tenant              Tenant?              @relation(fields: [tenantId], references: [id])
  walletId            String?
  wallet              Wallet?              @relation(fields: [walletId], references: [id])
  reference           String               @unique
  type                LedgerTransactionType
  channel             BillingChannel
  description         String
  grossAmountUgx      Int                  @default(0)
  feeAmountUgx        Int                  @default(0)
  netAmountUgx        Int                  @default(0)
  sourceType          String?
  sourceId            String?
  metadata            Json?
  createdAt           DateTime             @default(now())
  entries             LedgerEntry[]
  billingTransaction  BillingTransaction?

  @@index([tenantId, createdAt])
}

model LedgerEntry {
  id                  String            @id @default(uuid())
  ledgerTransactionId String
  ledgerTransaction   LedgerTransaction @relation(fields: [ledgerTransactionId], references: [id])
  tenantId            String?
  tenant              Tenant?           @relation(fields: [tenantId], references: [id])
  walletId            String?
  wallet              Wallet?           @relation(fields: [walletId], references: [id])
  accountCode         String
  direction           LedgerDirection
  amountUgx           Int
  memo                String?
  createdAt           DateTime          @default(now())

  @@index([tenantId, createdAt])
  @@index([walletId, createdAt])
}

model VoucherRedemption {
  id                String    @id @default(uuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  voucherId         String    @unique
  voucher           Voucher   @relation(fields: [voucherId], references: [id])
  packageId         String
  package           Package   @relation(fields: [packageId], references: [id])
  redeemedByUserId  String?
  redeemedByUser    User?     @relation("VoucherRedemptionActor", fields: [redeemedByUserId], references: [id])
  hotspotId         String?
  hotspot           Hotspot?  @relation(fields: [hotspotId], references: [id])
  customerReference String?
  sessionReference  String?
  createdAt         DateTime  @default(now())
  activation        PackageActivation?
  networkSessions   NetworkSession[]

  @@index([tenantId, createdAt])
}

model Payment {
  id                  String             @id @default(uuid())
  tenantId            String
  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  packageId           String
  package             Package            @relation(fields: [packageId], references: [id])
  billingTransactionId String?           @unique
  billingTransaction  BillingTransaction? @relation(fields: [billingTransactionId], references: [id])
  provider            PaymentProvider    @default(YO_UGANDA)
  method              PaymentMethod      @default(MOBILE_MONEY)
  network             PaymentNetwork     @default(UNKNOWN)
  status              PaymentStatus      @default(INITIATED)
  amountUgx           Int
  currency            String             @default("UGX")
  phoneNumber         String
  customerReference   String?
  externalReference   String             @unique
  providerReference   String?            @unique
  idempotencyKey      String             @unique
  providerStatus      String?
  statusMessage       String?
  requestPayload      Json?
  responsePayload     Json?
  metadata            Json?
  initiatedAt         DateTime           @default(now())
  completedAt         DateTime?
  failedAt            DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  webhooks            PaymentWebhook[]
  activation          PackageActivation?

  @@index([tenantId, createdAt])
  @@index([status, createdAt])
}

model PaymentWebhook {
  id                 String         @id @default(uuid())
  tenantId           String?
  tenant             Tenant?        @relation(fields: [tenantId], references: [id])
  paymentId          String?
  payment            Payment?       @relation(fields: [paymentId], references: [id])
  provider           PaymentProvider @default(YO_UGANDA)
  eventType          PaymentEventType
  externalReference  String?
  providerReference  String?
  verificationStatus String?
  headers            Json
  payload            Json
  notes              String?
  isProcessed        Boolean        @default(false)
  processedAt        DateTime?
  createdAt          DateTime       @default(now())

  @@index([paymentId, createdAt])
  @@index([externalReference, createdAt])
}

model PackageActivation {
  id                  String                 @id @default(uuid())
  tenantId            String
  tenant              Tenant                 @relation(fields: [tenantId], references: [id])
  packageId           String
  package             Package                @relation(fields: [packageId], references: [id])
  paymentId           String?                @unique
  payment             Payment?               @relation(fields: [paymentId], references: [id])
  voucherRedemptionId String?                @unique
  voucherRedemption   VoucherRedemption?     @relation(fields: [voucherRedemptionId], references: [id])
  hotspotId           String?
  hotspot             Hotspot?               @relation(fields: [hotspotId], references: [id])
  source              PackageActivationSource
  status              PackageActivationStatus @default(ACTIVE)
  customerReference   String?
  accessPhoneNumber   String?
  durationMinutes     Int
  dataLimitMb         Int?
  deviceLimit         Int?
  downloadSpeedKbps   Int?
  uploadSpeedKbps     Int?
  startedAt           DateTime               @default(now())
  endsAt              DateTime
  metadata            Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  sessions            NetworkSession[]

  @@index([tenantId, status, endsAt])
  @@index([accessPhoneNumber, status])
}

model AgentCommission {
  id                  String             @id @default(uuid())
  tenantId            String
  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  agentId             String
  agent               Agent              @relation(fields: [agentId], references: [id])
  walletId            String?
  wallet              Wallet?            @relation(fields: [walletId], references: [id])
  sourceTransactionId String             @unique
  sourceTransaction   BillingTransaction @relation("AgentCommissionSource", fields: [sourceTransactionId], references: [id])
  payoutTransactionId String?            @unique
  payoutTransaction   BillingTransaction? @relation("AgentCommissionPayout", fields: [payoutTransactionId], references: [id])
  settlementId        String?
  settlement          Settlement?        @relation(fields: [settlementId], references: [id])
  status              CommissionStatus   @default(ACCRUED)
  basisAmountUgx      Int
  rateBps             Int
  amountUgx           Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([tenantId, createdAt])
  @@index([agentId, status])
}

model Settlement {
  id             String           @id @default(uuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  agentId        String
  agent          Agent            @relation(fields: [agentId], references: [id])
  walletId       String
  wallet         Wallet           @relation(fields: [walletId], references: [id])
  reference      String           @unique
  status         SettlementStatus @default(DRAFT)
  periodStart    DateTime
  periodEnd      DateTime
  openingFloatUgx Int             @default(0)
  closingFloatUgx Int             @default(0)
  grossSalesUgx  Int              @default(0)
  commissionsUgx Int              @default(0)
  payableAmountUgx Int            @default(0)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  commissions    AgentCommission[]
  disbursements  Disbursement[]

  @@index([tenantId, createdAt])
  @@index([agentId, status])
}

model Disbursement {
  id                  String              @id @default(uuid())
  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  agentId             String
  agent               Agent               @relation(fields: [agentId], references: [id])
  settlementId        String?
  settlement          Settlement?         @relation(fields: [settlementId], references: [id])
  walletId            String
  wallet              Wallet              @relation(fields: [walletId], references: [id])
  billingTransactionId String?            @unique
  billingTransaction  BillingTransaction? @relation(fields: [billingTransactionId], references: [id])
  reference           String              @unique
  method              DisbursementMethod  @default(MOBILE_MONEY)
  status              DisbursementStatus  @default(PENDING)
  amountUgx           Int
  destinationReference String?
  providerReference   String?
  notes               String?
  metadata            Json?
  initiatedAt         DateTime            @default(now())
  completedAt         DateTime?
  failedAt            DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([tenantId, createdAt])
  @@index([agentId, status])
}

model FeatureLimit {
  id                   String               @id @default(uuid())
  tenantId             String?
  tenant               Tenant?              @relation(fields: [tenantId], references: [id])
  code                 String
  name                 String
  category             FeatureLimitCategory
  description          String?
  unit                 String?
  isEnabled            Boolean              @default(true)
  limitValue           Int?
  warningThresholdPct  Int                  @default(80)
  hardLimit            Boolean              @default(false)
  notes                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, category])
}

model SupportTicket {
  id                String               @id @default(uuid())
  tenantId          String
  tenant            Tenant               @relation(fields: [tenantId], references: [id])
  reference         String
  subject           String
  category          String
  priority          SupportTicketPriority @default(NORMAL)
  status            SupportTicketStatus   @default(OPEN)
  channel           SupportTicketChannel  @default(PORTAL)
  customerReference String?
  phoneNumber       String?
  email             String?
  openedBy          String?
  assignedTo        String?
  latestResponseAt  DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  messages          SupportTicketMessage[]

  @@unique([tenantId, reference])
  @@index([tenantId, status, createdAt])
  @@index([priority, createdAt])
}

model SupportTicketMessage {
  id         String        @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorName String
  authorRole String
  body       String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([ticketId, createdAt])
}

model AuditLog {
  id         String        @id @default(uuid())
  tenantId   String?
  tenant     Tenant?       @relation(fields: [tenantId], references: [id])
  userId     String?
  actorName  String?
  actorEmail String?
  action     String
  entity     String
  entityId   String?
  severity   AuditSeverity @default(INFO)
  ipAddress  String?
  userAgent  String?
  details    Json?
  createdAt  DateTime      @default(now())

  @@index([tenantId, createdAt])
  @@index([entity, createdAt])
  @@index([severity, createdAt])
}
